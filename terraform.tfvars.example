aws_region   = "us-east-1"
project_name = "365scores-idan-webapp"
environment  = "dev"

# Optional SSH access. Leave null/empty for no inbound SSH.
key_name                = null
allowed_ssh_cidr_blocks = []

# Custom domain. The hosted zone must already exist in Route 53.
domain_name    = ""
hosted_zone_id = ""

# Set true to create an ACM certificate and redirect HTTP to HTTPS.
enable_https = false

instance_type      = "t3.micro"
enable_backend_tls = true
enable_nat_gateway = true
single_nat_gateway = true
min_size           = 2
desired_capacity   = 2
max_size           = 4

# Production hardening. These add observability and protection, but may add AWS cost.
enable_waf                           = true
enable_vpc_flow_logs                 = true
enable_asg_cpu_scaling               = true
asg_target_cpu_utilization           = 50
enable_deletion_protection           = false
log_retention_days                   = 30
api_throttle_rate_limit              = 20
api_throttle_burst_limit             = 40
lambda_reserved_concurrent_executions = -1
alarm_actions                        = []

tags = {
  Owner = "365Scores"
}
